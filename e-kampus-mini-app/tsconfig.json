{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "types": [
      "react-native"
    ]
  },
  "exclude": [
    "dist",
    "dist-cf",
    "dist-final",
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
